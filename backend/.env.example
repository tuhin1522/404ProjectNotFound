# ==========================================
# Backend Environment Variables
# ==========================================

# Django Security
# Provide a strong, random, and secret string in production
SECRET_KEY=django-insecure-your-secret-key-here

# Debug mode (Set to False in production)
DEBUG=False

# Allowed hosts (Your production domains, comma-separated)
# Example: api.yourdomain.com,imageannotation.vercel.app
ALLOWED_HOSTS=imageannotation.vercel.app,localhost,127.0.0.1

# CORS Origins (Your frontend domains, comma-separated)
# Example: https://yourfrontend.com,http://localhost:3000
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app,http://localhost:3000

# Database Configuration
# The PostgreSQL connection string
DATABASE_URL=postgresql://user:password@hostname:port/dbname?sslmode=require

# Cloudinary (Required for image uploads on Vercel)
# Format: cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# SSL Redirect (Set to True in production to force HTTPS)
SECURE_SSL_REDIRECT=True
